{
  "name": "capturequest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "terrain:generate": "node scripts/generate-overworld-preview.mjs",
    "terrain:validate": "node scripts/validate-overworld-preview.mjs",
    "terrain:test": "npm run terrain:generate && npm run terrain:validate",
    "audio:manifest": "node scripts/generate_audio_manifest.mjs",
    "audio:sync": "node scripts/sync_extractor_audio_manifest.mjs",
    "bootstrap:assets": "./scripts/bootstrap_capturequest.sh --assets-only",
    "bootstrap:fresh": "./scripts/bootstrap_capturequest.sh",
    "db:bootstrap": "./server/scripts/bootstrap_postgres.sh --create --reset",
    "tygo": "cd server && go run github.com/gzuidhof/tygo@latest generate && cd .. && ./scripts/fix-tygo-casing.sh",
    "server:go": "npm run tygo && cd server && if command -v air > /dev/null; then air; else go run ./cmd/server; fi",
    "server": "if [ -f .env ]; then set -a; . .env; set +a; fi; export HTTP_PORT=${HTTP_PORT:-8080}; npm run server:go",
    "dev:all": "npm run audio:manifest && if [ -f .env ]; then set -a; . .env; set +a; fi; eval \"$(node scripts/dev-port-env.mjs)\"; export VITE_LOCAL_DEV=${VITE_LOCAL_DEV:-true}; export VITE_OFFLINE_ASSETS=${VITE_OFFLINE_ASSETS:-false}; concurrently -k -p \"[{name}]\" -n \"server,client\" -c \"magenta,cyan\" \"npm run server:go\" \"sleep 3 && npm run dev\"",
    "dev:test": "VITE_TEST_MODE=true CAPTUREQUEST_TEST_MODE=true npm run dev:all"
  },
  "dependencies": {
    "@swc/plugin-styled-components": "3.0.0",
    "@tanstack/react-query-devtools": "^5.58.0",
    "jszip": "^3.10.1",
    "phaser": "^3.88.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.4.6",
    "react-icons": "^5.5.0",
    "socket.io-client": "^4.7.2",
    "styled-components": "^6.1.13",
    "webfontloader": "^1.6.28",
    "zod": "^3.25.76",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.9",
    "@types/styled-components": "^5.1.34",
    "@types/webfontloader": "^1.6.38",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "babel-plugin-styled-components": "^2.1.4",
    "concurrently": "^8.2.2",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "redux-devtools-extension": "^2.13.9",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.57.1",
    "@rollup/rollup-linux-x64-musl": "^4.57.1",
    "@swc/core-linux-x64-gnu": "^1.7.18"
  }
}
